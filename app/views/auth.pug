extends layout

block content
  section.auth-page
    .auth-shell
      .auth-intro
        p.kicker School Access
        h1= authMode === "register" ? "Create your Smart School account" : "Welcome back to Smart School"
        if authMode === "register"
          p.auth-copy Register students, teachers, and staff in one place with secure onboarding for every school role.
        else
          p.auth-copy Sign in to manage attendance, track academic progress, and stay connected to your school's daily workflow.

        .auth-highlights
          article.auth-highlight
            h2 Role-based access
            p Separate experiences for students, teachers, and administrators.
          article.auth-highlight
            h2 Daily-ready dashboard
            p Attendance, assignments, notices, and schedules are available from one workspace.
          article.auth-highlight
            h2 Secure records
            p Keep school data protected with verified users and structured account details.

      .auth-card
        .auth-tabs
          a.auth-tab(class=authMode === "login" ? "active" : "", href="/login") Login
          a.auth-tab(class=authMode === "register" ? "active" : "", href="/register") Register

        if authMode === "register"
          form.auth-form(action="#", method="post")
            .form-grid
              .form-field
                label(for="full_name") Full Name
                input#full_name(type="text", name="full_name", placeholder="Enter full name")
              .form-field
                label(for="role") Role
                select#role(name="role")
                  option(value="student") Student
                  option(value="teacher") Teacher
                  option(value="admin") Administrator
              .form-field
                label(for="class_name") Class / Department
                input#class_name(type="text", name="class_name", placeholder="Grade 10 - A")
              .form-field
                label(for="email") Email Address
                input#email(type="email", name="email", placeholder="name@school.edu")
              .form-field
                label(for="phone") Phone Number
                input#phone(type="tel", name="phone", placeholder="+91 98765 43210")
              .form-field
                label(for="password") Password
                input#password(type="password", name="password", placeholder="Create password")
            .form-field
              label(for="about") Notes
              textarea#about(name="about", rows="4", placeholder="Any onboarding notes or guardian details")
            button.btn-primary.auth-submit(type="submit") Create Account
            p.auth-switch
              | Already have an account? 
              a(href="/login") Sign in here
        else
          form.auth-form(action="#", method="post")
            .form-field
              label(for="login_role") Login As
              select#login_role(name="role")
                option(value="student") Student
                option(value="teacher") Teacher
                option(value="admin") Administrator
            .form-field
              label(for="login_email") Email Address
              input#login_email(type="email", name="email", placeholder="name@school.edu")
            .form-field
              label(for="login_password") Password
              input#login_password(type="password", name="password", placeholder="Enter password")
            .auth-row
              label.checkbox
                input(type="checkbox", name="remember_me")
                span Remember me
              a.auth-link(href="/register") Create an account
            button.btn-primary.auth-submit(type="submit") Login
            p.auth-switch
              | New to Smart School? 
              a(href="/register") Register now
