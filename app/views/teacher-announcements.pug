extends layout

block content
  .portal-shell
    - const teacherId = announcementPage.teacherId
    - const activeSidebar = "announcements"
    include teachersidebar

    section.dashboard-wrap.portal-content
      .dashboard-head
        .dashboard-intro
          p.kicker Teacher Announcements
          h1 Create Announcement
          p Share clear updates with #{announcementPage.className}.
        .dashboard-class
          p.label Class
          p.value= announcementPage.className

      if announcementMessage
        p.auth-feedback(class=announcementMessage.type === "error" ? "auth-feedback-error" : "auth-feedback-success")= announcementMessage.text

      .profile-grid
        article.dashboard-panel.profile-card.profile-card-wide
          h2 New Announcement
          form.profile-form(action="/teachers/announcements", method="post")
            input(type="hidden", name="teacher_id", value=announcementPage.teacherId)
            .form-grid
              .form-field
                label(for="title") Title
                input#title(type="text", name="title", placeholder="Enter announcement title")
              .form-field
                label(for="category") Category
                select#category(name="category")
                  option(value="Academic") Academic
                  option(value="Exam") Exam
                  option(value="Event") Event
                  option(value="Attendance") Attendance
                  option(value="General") General
            .form-field
              label(for="description") Description
              textarea#description(name="description", rows="5", placeholder="Write the update students should receive")
            button.btn-primary(type="submit") Publish Announcement

        article.dashboard-panel.profile-card.profile-card-wide
          h2 Published Announcements
          if announcementPage.announcements.length
            ul.announcement-list
              each announcement in announcementPage.announcements
                li.announcement-item
                  form.announcement-edit-form(action=`/teachers/announcements/${announcement.id}/update`, method="post")
                    input(type="hidden", name="teacher_id", value=announcementPage.teacherId)
                    .form-grid
                      .form-field
                        label(for=`title_${announcement.id}`) Title
                        input(id=`title_${announcement.id}`, type="text", name="title", value=announcement.title)
                      .form-field
                        label(for=`category_${announcement.id}`) Category
                        select(id=`category_${announcement.id}`, name="category")
                          option(value="Academic", selected=announcement.category === "Academic") Academic
                          option(value="Exam", selected=announcement.category === "Exam") Exam
                          option(value="Event", selected=announcement.category === "Event") Event
                          option(value="Attendance", selected=announcement.category === "Attendance") Attendance
                          option(value="General", selected=announcement.category === "General") General
                    .form-field
                      label(for=`description_${announcement.id}`) Description
                      textarea(id=`description_${announcement.id}`, name="description", rows="4")= announcement.description
                    p.assignment-meta Posted #{announcement.postedOn}
                    .announcement-actions
                      button.btn-primary(type="submit") Save Changes
                  form(action=`/teachers/announcements/${announcement.id}/delete`, method="post")
                    input(type="hidden", name="teacher_id", value=announcementPage.teacherId)
                    button.btn-danger(type="submit") Delete
          else
            p.profile-notes No announcements published yet.
