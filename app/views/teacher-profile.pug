extends layout

block content
  .portal-shell
    - const teacherId = profile.teacherId
    - const activeSidebar = "profile"
    include teachersidebar

    section.dashboard-wrap.portal-content
      .dashboard-head
        .dashboard-intro
          p.kicker Teacher Profile
          h1= profile.teacherName
          p Review and update your school account details.
        .dashboard-class
          p.label Role
          p.value Teacher

      if profileMessage
        p.auth-feedback(class=profileMessage.type === "error" ? "auth-feedback-error" : "auth-feedback-success")= profileMessage.text

      .profile-grid
        article.dashboard-panel.profile-card
          h2 Personal Details
          dl.profile-list
            .profile-row
              dt Full Name
              dd= profile.teacherName
            .profile-row
              dt Email
              dd= profile.email
            .profile-row
              dt Phone
              dd= profile.phone || "Not added"

        article.dashboard-panel.profile-card
          h2 Class Details
          dl.profile-list
            .profile-row
              dt Assigned Class
              dd= profile.className
            .profile-row
              dt Teacher ID
              dd= profile.teacherId

        article.dashboard-panel.profile-card.profile-card-wide
          h2 Notes
          p.profile-notes= profile.about || "No profile notes added."

        article.dashboard-panel.profile-card.profile-card-wide
          h2 Edit Profile
          form.profile-form(action="/teachers/profile", method="post")
            input(type="hidden", name="teacher_id", value=profile.teacherId)
            .form-grid
              .form-field
                label(for="full_name") Full Name
                input#full_name(type="text", name="full_name", value=profile.teacherName)
              .form-field
                label(for="email") Email
                input#email(type="email", name="email", value=profile.email)
              .form-field
                label(for="class_name") Assigned Class
                input#class_name(type="text", name="class_name", value=profile.className)
              .form-field
                label(for="phone") Phone
                input#phone(type="tel", name="phone", value=profile.phone || "")
            .form-field
              label(for="about") Notes
              textarea#about(name="about", rows="4")= profile.about || ""
            button.btn-primary(type="submit") Save Profile

        article.dashboard-panel.profile-card.profile-card-wide
          h2 Change Password
          form.profile-form(action="/teachers/password", method="post")
            input(type="hidden", name="teacher_id", value=profile.teacherId)
            .form-grid
              .form-field
                label(for="current_password") Current Password
                input#current_password(type="password", name="current_password")
              .form-field
                label(for="new_password") New Password
                input#new_password(type="password", name="new_password")
              .form-field
                label(for="confirm_password") Confirm Password
                input#confirm_password(type="password", name="confirm_password")
            button.btn-primary(type="submit") Change Password
