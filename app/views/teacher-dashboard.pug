extends layout

block content
  .portal-shell
    - const teacherId = dashboard.teacherId
    - const activeSidebar = "dashboard"
    include teachersidebar

    section.dashboard-wrap.portal-content
      .dashboard-head
        .dashboard-intro
          p.kicker Teacher Workspace
          h1 Teacher Dashboard
          p Welcome back #{dashboard.teacherName}. Here is your teaching snapshot for #{dashboard.today}.
        .dashboard-class
          p.label Current Class
          p.value= dashboard.className

      .dashboard-stats
        each stat in dashboard.stats
          article.dashboard-card
            p.card-label= stat.label
            p.card-value= stat.value

      .dashboard-grid.teacher-dashboard-grid
        article.dashboard-panel
          h2 Today's Schedule
          table.schedule-table
            thead
              tr
                th Time
                th Subject
                th Room
                th Status
            tbody
              each period in dashboard.periods
                tr
                  td= period.time
                  td= period.subject
                  td= period.room
                  td
                    span.status-pill(class=period.status.toLowerCase())= period.status

        article.dashboard-panel
          h2 Task Checklist
          ul.dashboard-list
            each todo in dashboard.todos
              li
                if dashboard.doneTodos && dashboard.doneTodos.includes(todo)
                  span.status-pill.completed Done
                else
                  span.status-pill.next Pending
                |  #{todo}

        article.dashboard-panel
          h2 School Notices
          ul.dashboard-list.notice-list
            each notice in dashboard.notices
              li= notice
