extends layout

block content
  .portal-shell
    - const teacherId = reportPage.teacherId
    - const activeSidebar = "performance-reports"
    include teachersidebar

    section.dashboard-wrap.portal-content
      .dashboard-head
        .dashboard-intro
          p.kicker Teacher Workspace
          h1 Performance Reports
          p Review each student's academic progress and identify who needs support.
        .dashboard-class
          p.label Teacher
          p.value= reportPage.teacherName
          p.label Current Class
          p.value= reportPage.className

      .dashboard-stats
        article.dashboard-card
          p.card-label Students
          p.card-value= reportPage.summary.totalStudents
        article.dashboard-card
          p.card-label Reports Ready
          p.card-value= reportPage.summary.completedReports
        article.dashboard-card
          p.card-label Class Average
          p.card-value= reportPage.summary.classAverage
        article.dashboard-card
          p.card-label High Performers
          p.card-value= reportPage.summary.highPerformers

      article.dashboard-panel
        h2 Generate Report
        form.filter-form(method="get", action="/teachers/performance-reports")
          input(type="hidden", name="teacher_id", value=reportPage.teacherId)
          .filter-grid.report-filter-grid
            label.form-field
              span Subject
              input(type="text", name="subject", value=reportPage.selectedSubject, placeholder="All Subjects or specific subject")
            label.form-field
              span Assessment Type
              select(name="assessment_type")
                option(value="All Types", selected=reportPage.selectedAssessmentType === "All Types") All Types
                option(value="Exam", selected=reportPage.selectedAssessmentType === "Exam") Exam
                option(value="Assignment", selected=reportPage.selectedAssessmentType === "Assignment") Assignment
            .filter-actions
              button.btn-secondary(type="submit") View Report

      article.dashboard-panel
        h2 Student Progress Summary
        if reportPage.rows.length
          table.schedule-table.attendance-table.report-table
            thead
              tr
                th Student
                th Roll Number
                th Assessments
                th Average
                th Latest
                th Last Updated
                th Performance
            tbody
              each row in reportPage.rows
                tr
                  td= row.student_name
                  td= row.roll_number
                  td= row.assessments_count
                  td= row.averagePercent
                  td= row.latestPercent
                  td= row.latestAssessmentDate
                  td= row.performanceBand
        else
          p.form-helper No marks are available for the selected filters.

      .dashboard-actions
        a.btn-secondary(href=`/teachers/dashboard?teacher_id=${reportPage.teacherId}`) Back to Dashboard
