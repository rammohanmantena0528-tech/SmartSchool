extends layout

block content
  .portal-shell
    - const teacherId = attendancePage.teacherId
    - const activeSidebar = "attendance"
    include teachersidebar

    section.dashboard-wrap.portal-content
      .dashboard-head
        .dashboard-intro
          p.kicker Teacher Workspace
          h1 Teacher Attendance
          if attendancePage.hasExistingAttendance
            p Review and update attendance for #{attendancePage.className} on #{attendancePage.today}.
          else
            p Mark daily attendance for #{attendancePage.className} on #{attendancePage.today}.
        .dashboard-class
          p.label Teacher
          p.value= attendancePage.teacherName
          p.label Current Class
          p.value= attendancePage.className

      article.dashboard-panel
        if attendancePage.hasExistingAttendance
          h2 Update Attendance
        else
          h2 Attendance Marking
        if attendancePage.message
          p.form-success= attendancePage.message.text

        form.filter-form(method="get", action="/teachers/attendance")
          input(type="hidden", name="teacher_id", value=attendancePage.teacherId)
          .filter-grid
            label.form-field
              span Date
              input(type="date", name="date", value=attendancePage.selectedDate)
            label.form-field
              span Subject
              select(name="subject")
                each subject in attendancePage.subjects
                  option(value=subject, selected=subject === attendancePage.selectedSubject)= subject
            .filter-actions
              button.btn-secondary(type="submit") Load List

        form(method="post", action="/teachers/attendance")
          input(type="hidden", name="teacher_id", value=attendancePage.teacherId)
          input(type="hidden", name="date", value=attendancePage.selectedDate)
          input(type="hidden", name="subject", value=attendancePage.selectedSubject)
          if attendancePage.hasExistingAttendance
            p.form-helper Existing attendance is loaded below. Change any row and submit to correct mistakes.
          else
            p.form-helper Select a status for each student to save today's attendance record.
          table.schedule-table.attendance-table
            thead
              tr
                th Student
                th Roll Number
                th Subject
                th Status
                th Remarks
            tbody
              each student in attendancePage.students
                tr
                  td= student.student_name
                  td= student.roll_number
                  td= attendancePage.selectedSubject
                  td
                    select.attendance-select(name=`status_${student.student_id}`)
                      option(value="") Select
                      option(value="Present", selected=student.status === "Present") Present
                      option(value="Absent", selected=student.status === "Absent") Absent
                      option(value="Late", selected=student.status === "Late") Late
                  td
                    input.attendance-remarks(
                      type="text"
                      name=`remarks_${student.student_id}`
                      value=student.remarks || ""
                      placeholder="Optional remark"
                    )

          .dashboard-actions
            if attendancePage.hasExistingAttendance
              button.btn-primary(type="submit") Update Attendance
            else
              button.btn-primary(type="submit") Save Attendance

      .dashboard-actions
        a.btn-secondary(href=`/teachers/dashboard?teacher_id=${attendancePage.teacherId}`) Back to Dashboard
