extends layout

block content
  .portal-shell
    - const studentId = dashboard.studentId
    - const activeSidebar = "dashboard"
    include studentsidebar

    section.dashboard-wrap.portal-content
      .dashboard-head
        .dashboard-intro
          p.kicker Student Workspace
          h1 Student Dashboard
          p Welcome back #{dashboard.studentName}. Here is your study snapshot for #{dashboard.today}.
        .dashboard-class
          p.label Class
          p.value= dashboard.className
          p.label Roll Number
          p.value= dashboard.rollNumber

      .dashboard-stats
        each stat in dashboard.stats
          article.dashboard-card
            p.card-label= stat.label
            p.card-value= stat.value

      .dashboard-grid.student-dashboard-grid
        article.dashboard-panel
          h2 Today's Schedule
          table.schedule-table
            thead
              tr
                th Time
                th Subject
                th Room
                th Status
            tbody
              each period in dashboard.periods
                tr
                  td= period.time
                  td= period.subject
                  td= period.room
                  td
                    span.status-pill(class=period.status.toLowerCase())= period.status

        article.dashboard-panel
          h2 Assignment Tracker
          ul.dashboard-list.assignment-list
            each assignment in dashboard.assignments
              li.assignment-item
                .assignment-copy
                  p.assignment-title= assignment.title
                  p.assignment-meta #{assignment.subject} • #{assignment.due}
                span.status-pill(class=assignment.progress.toLowerCase().replace(/[^a-z]/g, "-"))= assignment.progress

        article.dashboard-panel
          h2 Recent Marks
          if dashboard.marksPreview.length
            ul.dashboard-list.assignment-list
              each mark in dashboard.marksPreview
                li.assignment-item
                  .assignment-copy
                    p.assignment-title= mark.title
                    p.assignment-meta #{mark.subject} • #{mark.score}/#{mark.maxMarks}
          else
            p.profile-notes No marks uploaded yet.

        article.dashboard-panel
          h2 Announcements
          if dashboard.announcements.length
            ul.announcement-list
              each announcement in dashboard.announcements
                li.announcement-item
                  .announcement-head
                    h3= announcement.title
                    span.announcement-category= announcement.category
                  p.assignment-meta Posted #{announcement.postedOn}
                  p.announcement-description= announcement.description
          else
            p.profile-notes No announcements yet.

        article.dashboard-panel
          h2 School Notices
          ul.dashboard-list.notice-list
            each notice in dashboard.notices
              li= notice
